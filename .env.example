# ===== 主对话 LLM(DeepSeek V4-Flash via 官方 endpoint)=====
# 申请 key: https://platform.deepseek.com/
OPENAI_API_KEY=sk-your-deepseek-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-v4-flash

# ===== 视觉 LLM(Qwen3-VL-Flash via 阿里百炼)=====
# 申请 key: https://bailian.console.aliyun.com/
# 用于 extract_label_nutrition 工具读取宠物粮包装照
VISION_API_KEY=sk-your-dashscope-key
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen3-vl-flash

# ===== MySQL =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=pet_health_agent

# ===== JWT =====
SECRET_KEY=change-me-to-a-random-string

# ===== LangGraph Checkpoint(AsyncSqliteSaver)=====
CHECKPOINT_DB_PATH=nutrition_checkpoints.db
